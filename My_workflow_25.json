    {
      "parameters": {
        "jsCode": "// N8N Code Node - Convert JSON to Script Array\n// This code processes the TikTok ad script JSON and outputs a clean script array\n\n// Get the input data\nconst inputData = $input.item.json;\n\n// Extract the script_one, script_two, script_three from the JSON structure\nconst scriptData = inputData;\n\n// Create an array of scripts with a consistent structure\nconst scriptsArray = [\n  {\n    id: 1,\n    variation_label: scriptData.script_one.variation_label,\n    differentiation_strategy: scriptData.script_one.differentiation_strategy,\n    script_text: scriptData.script_one.script_text,\n    visual_recommendations: scriptData.script_one.visual_recommendations,\n    key_changes_from_original: scriptData.script_one.key_changes_from_original,\n    type: \"script\",\n    status: \"generated\"\n  },\n  {\n    id: 2,\n    variation_label: scriptData.script_two.variation_label,\n    differentiation_strategy: scriptData.script_two.differentiation_strategy,\n    script_text: scriptData.script_two.script_text,\n    visual_recommendations: scriptData.script_two.visual_recommendations,\n    key_changes_from_original: scriptData.script_two.key_changes_from_original,\n    type: \"script\",\n    status: \"generated\"\n  },\n  {\n    id: 3,\n    variation_label: scriptData.script_three.variation_label,\n    differentiation_strategy: scriptData.script_three.differentiation_strategy,\n    script_text: scriptData.script_three.script_text,\n    visual_recommendations: scriptData.script_three.visual_recommendations,\n    key_changes_from_original: scriptData.script_three.key_changes_from_original,\n    type: \"script\",\n    status: \"generated\"\n  }\n];\n\n// Return the scripts array\nreturn {\n  scripts: scriptsArray,\n  total_scripts: scriptsArray.length,\n  generated_at: new Date().toISOString()\n};"
      },
